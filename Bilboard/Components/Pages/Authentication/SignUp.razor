@using Bilboard.ViewModels
@inject NavigationManager Navigation
@inject HttpClient Client

<EditForm Model="@SignInVM" OnValidSubmit="HandleSignUp" class="needs-validation" novalidate>
    <DataAnnotationsValidator />

    <div class="form-floating mb-3">
        <InputText @bind-Value="SignInVM.Email" @oninput="(e => OnCheckEmailInput(((ChangeEventArgs)e).Value?.ToString()))" id="Firstname" type="email" class="@(EmailValid + " form-control")" placeholder="Firstname" required />
        <label for="Firstname">Firstname</label>
        <div class="invalid-tooltip">
            Must be a valid first name.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-Value="SignInVM.Email" @oninput="(e => OnCheckEmailInput(((ChangeEventArgs)e).Value?.ToString()))" id="Lastname" type="email" class="@(EmailValid + " form-control")" placeholder="Lastname" required />
        <label for="Lastname">Lastname</label>
        <div class="invalid-tooltip">
            Must be a valid last name.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-Value="SignInVM.Email" @oninput="(e => OnCheckEmailInput(((ChangeEventArgs)e).Value?.ToString()))" id="Username" type="email" class="@(EmailValid + " form-control")" placeholder="Username" required />
        <label for="Username">Email</label>
        <div class="invalid-tooltip">
            Must be a valid email address.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-value="SignInVM.Password" @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="Password" type="password" class="@(PassValid + " form-control")" placeholder="Password" required />
        <label for="Password">Password</label>
        <div class="invalid-tooltip">
            Must includes capitals and numbers.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-value="SignInVM.Password" @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="ConfirmPassword" type="password" class="@(PassValid + " form-control")" placeholder="Confirm Password" required />
        <label for="ConfirmPassword">Confirm Password</label>
        <div class="invalid-tooltip">
            Must includes capitals and numbers.
        </div>
    </div>
    <div class="form-group mb-3 text-center">
        <button type="submit" class="@("btn border btn-block")">
            <span class="@(Loading + " spinner-border spinner-border-sm")" aria-hidden="true"></span>
            Sign Up
        </button>
    </div>
    <div class="text-center">
        <a class="d-block" href="signin">Sign In</a>
        <a class="d-block" href="forgot">forgot your password?</a>
    </div>
</EditForm>

@code {
    private SignInViewModel SignInVM = new();
    public string EmailValid { get; set; } = string.Empty;
    public string PassValid { get; set; } = string.Empty;
    public string Loading { get; set; } = "d-none";

    // Callback delegates from parent
    [Parameter]
    public Func<string, Task>? OnShowToast { get; set; }

    [Parameter]
    public Func<string, Task<bool>>? OnCheckEmailInput { get; set; }

    [Parameter]
    public Func<string, Task<bool>>? OnCheckPasswordInput { get; set; }

    [Parameter]
    public Func<Task>? OnHandleSignIn { get; set; }

    private async Task HandleSignUp()
    {
        Console.WriteLine("Sign up successful");
    }
}
