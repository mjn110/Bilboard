@using Bilboard.ViewModels
@using RestSharp;
@inject NavigationManager Navigation
@inject HttpClient Client
@inject IJwtAuthService JwtAuthService

<EditForm Model="@SignUpVM" OnValidSubmit="HandleSignUp" class="needs-validation" novalidate>
    <DataAnnotationsValidator />

    <div class="form-floating mb-3">
        <InputText @bind-Value="SignUpVM.FirstName"
                   @oninput="(e => OnCheckEmailInput(((ChangeEventArgs)e).Value?.ToString()))" id="Firstname" type="email"
                   class="@(EmailValid + " form-control")" placeholder="Firstname" required />
        <label for="Firstname">Firstname</label>
        <div class="invalid-tooltip">
            Must be a valid first name.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-Value="SignUpVM.LastName"
                   @oninput="(e => OnCheckEmailInput(((ChangeEventArgs)e).Value?.ToString()))" id="Lastname" type="email"
                   class="@(EmailValid + " form-control")" placeholder="Lastname" required />
        <label for="Lastname">Lastname</label>
        <div class="invalid-tooltip">
            Must be a valid last name.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-Value="SignUpVM.Email"
                   @oninput="(e => OnCheckEmailInput(((ChangeEventArgs)e).Value?.ToString()))" id="Username" type="email"
                   class="@(EmailValid + " form-control")" placeholder="Username" required />
        <label for="Username">Email</label>
        <div class="invalid-tooltip">
            Must be a valid email address.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-value="SignUpVM.Password"
                   @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="Password" type="password"
                   class="@(PassValid + " form-control")" placeholder="Password" required />
        <label for="Password">Password</label>
        <div class="invalid-tooltip">
            Must includes capitals and numbers.
        </div>
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-value="SignUpVM.Password"
                   @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="ConfirmPassword"
                   type="password" class="@(PassValid + " form-control")" placeholder="Confirm Password" required />
        <label for="ConfirmPassword">Confirm Password</label>
        <div class="invalid-tooltip">
            Must includes capitals and numbers.
        </div>
    </div>
    <div class="form-group mb-3 text-center">
        <button type="submit" class="@("btn border btn-block")">
            <span class="@(Loading + " spinner-border spinner-border-sm")" aria-hidden="true"></span>
            Sign Up
        </button>
    </div>
    <div class="text-center">
        <a class="d-block" href="signin">Sign In</a>
        <a class="d-block" href="forgot">forgot your password?</a>
    </div>
</EditForm>

@code {
    private SignUpViewModel SignUpVM = new();
    public string EmailValid { get; set; } = string.Empty;
    public string PassValid { get; set; } = string.Empty;
    public string Loading { get; set; } = "d-none";

    // Callback delegates from parent
    [Parameter]
    public Func<string, Task>? OnShowToast { get; set; }

    [Parameter]
    public Func<string, Task<bool>>? OnCheckEmailInput { get; set; }

    [Parameter]
    public Func<string, Task<bool>>? OnCheckPasswordInput { get; set; }

    [Parameter]
    public Func<Task>? OnHandleSignIn { get; set; }

    private async Task HandleSignUp()
    {
        var EmailValidation = await OnCheckEmailInput(SignUpVM.Email);
        var PassValidation = await OnCheckPasswordInput(SignUpVM.Password);
        if (EmailValidation && PassValidation)
        {
            Loading = string.Empty;
            try
            {
                var response = await Client.PostAsJsonAsync("/api/Account/SignUp", SignUpVM);
                if (response.IsSuccessStatusCode)
                {
                    var content = await response.Content.ReadFromJsonAsync<global::Application.DTO.Account.SignInResponseDto>();

                    // Save JWT token to localStorage
                    await JwtAuthService.SaveTokenAsync(content.Token);

                    Console.WriteLine("Sign up successful");
                    EmailValid = "valid";
                    PassValid = "valid";
                    await Task.Delay(1000);
                    if (OnShowToast != null)
                        await OnShowToast("Account created successfully!");
                    Loading = "d-none";
                    StateHasChanged();
                    var MailResponse = await Client.GetAsync("https://api.brevo.com/v3/account");
                    await Task.Delay(2000);
                    Navigation.NavigateTo("/Boards");
                }
                else
                {
                    Console.WriteLine("Sign up failed: " + response.ReasonPhrase);
                    EmailValid = "is-invalid";
                    PassValid = "is-invalid";
                    Loading = "d-none";
                    StateHasChanged();
                    // Handle error
                    if (OnShowToast != null)
                        await OnShowToast("Incorrect details.");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Sign up error: {ex.Message}");
                EmailValid = "is-invalid";
                PassValid = "is-invalid";
                Loading = "d-none";
                StateHasChanged();
                if (OnShowToast != null)
                    await OnShowToast("An error occurred during sign up.");
            }
        }
        else
        {
            // Validation failed
            Console.WriteLine("Validation failed");
            if (OnShowToast != null)
                await OnShowToast("The username or password is not valid.");
            // Handle validation error
        }
    }


}
