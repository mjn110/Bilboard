@using Bilboard.ViewModels
@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation
@inject HttpClient Client
@layout Authentication

<EditForm Model="@ResetVM" OnValidSubmit="HandleResetPassword" class="needs-validation" novalidate>
    <DataAnnotationsValidator />

    <div class="form-floating mb-3">
        <InputText @bind-Value="ResetVM.Password" @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="Username" type="email" class="@(PassValid + " form-control rounded-4")" placeholder="New Password" required />
        <label for="Username">Email</label>
        <div class="invalid-tooltip">
            Must be a valid email address.
        </div>
    </div>
    <div class="form-floating mb-3">
        <InputText @bind-Value="ResetVM.ConfirmPassword" @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="Username" type="email" class="@(PassValid + " form-control rounded-4")" placeholder="Confirm New Password" required />
        <label for="Username">Email</label>
        <div class="invalid-tooltip">
            Must be a valid email address.
        </div>
    </div>
    <div class="form-group mb-3 text-center">
        <button type="submit" class="@("btn border btn-block")">
            <span class="@(Loading + " spinner-border spinner-border-sm")" aria-hidden="true"></span>
            Reset Password
        </button>
    </div>
    <div class="text-center">
        <a href="signin">Sign In</a>
        <a>/</a>
        <a href="signup">Sign Up</a>
    </div>
</EditForm>

@code {
    private ResetViewModel ResetVM = new();
    public string PassValid { get; set; } = string.Empty;
    public string Loading { get; set; } = "d-none";

    [Parameter]
    public string? Email { get; set; }

    [Parameter]
    public string? Token { get; set; }

    // Callback delegates from parent
    [Parameter]
    public Func<string, Task>? OnShowToast { get; set; }

    [Parameter]
    public Func<string, Task<bool>>? OnCheckPasswordInput { get; set; }

    [Parameter]
    public Func<Task>? OnHandleResetPassword { get; set; }

    private async Task HandleResetPassword()
    {
        var PassValidation = await OnCheckPasswordInput(ResetVM.Password);
        if (PassValidation)
        {
            Loading = string.Empty;
            // Validation succeed so perform sign-in logic here
            var response = await Client.PostAsJsonAsync("/api/Account/ResetPasswordRequest", ResetVM.ConfirmPassword);
            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("Sign in successful");
                PassValid = "valid";
                await Task.Delay(1000);
                if (OnShowToast != null)
                    await OnShowToast(response.Content.ReadAsStringAsync().Result);
                Loading = "d-none";
                StateHasChanged();
                await Task.Delay(2000);
                Navigation.NavigateTo("/signin");
            }
            else
            {
                Console.WriteLine("Reset password request failed!");
                PassValid = "is-invalid";
                Loading = "d-none";
                StateHasChanged();
                // Handle error
                if (OnShowToast != null)
                    await OnShowToast("Failed to request password reset.");
            }
        }
        else
        {
            // Validation failed
            Console.WriteLine("Validation failed");
            if (OnShowToast != null)
                await OnShowToast("The email address is not valid.");
            // Handle validation error
        }
    }

}