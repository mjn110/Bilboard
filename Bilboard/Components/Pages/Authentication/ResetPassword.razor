@using Bilboard.ViewModels
@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation
@inject HttpClient Client
@layout Authentication

<EditForm Model="@ResetVM" OnValidSubmit="HandleResetPassword" class="needs-validation" novalidate>
    <DataAnnotationsValidator />

    <div class="form-floating mb-3">
        <InputText @bind-Value="ResetVM.Password" @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="Password" type="password" class="@(PassValid + " form-control rounded-4")" placeholder="New Password" required />
        <label for="Password">New Password</label>
        <div class="invalid-tooltip">
            Must be a valid email address.
        </div>
    </div>
    <div class="form-floating mb-3">
        <InputText @bind-Value="ResetVM.ConfirmPassword" @oninput="(e => OnCheckPasswordInput(((ChangeEventArgs)e).Value?.ToString()))" id="ConfirmPassword" type="password" class="@(PassValid + " form-control rounded-4")" placeholder="Confirm New Password" required />
        <label for="ConfirmPassword">Confirm New Password</label>
        <div class="invalid-tooltip">
            Must be a valid email address.
        </div>
    </div>
    <div class="form-group mb-3 text-center">
        <button type="submit" class="@("btn border btn-block")">
            <span class="@(Loading + " spinner-border spinner-border-sm")" aria-hidden="true"></span>
            Reset Password
        </button>
    </div>
    <div class="text-center">
        <a href="signin">Sign In</a>
        <a>/</a>
        <a href="signup">Sign Up</a>
    </div>
</EditForm>

@code {
    private ResetViewModel ResetVM = new();
    public string PassValid { get; set; } = string.Empty;
    public string Loading { get; set; } = "d-none";

    [Parameter]
    public string? Email { get; set; }

    [Parameter]
    public string? Token { get; set; }

    // Callback delegates from parent
    [Parameter]
    public Func<string, Task>? OnShowToast { get; set; }

    [Parameter]
    public Func<string, Task<bool>>? OnCheckPasswordInput { get; set; }

    protected override void OnInitialized()
    {
        ExtractQueryParameters();
    }

    private void ExtractQueryParameters()
    {
        var uri = new Uri(Navigation.Uri);
        var queryParams = System.Web.HttpUtility.ParseQueryString(uri.Query);

        ResetVM.Email = queryParams["email"];
        ResetVM.Token = queryParams["token"];
    }

    private async Task HandleResetPassword()
    {
        Console.WriteLine($"Reset Password - Email: {ResetVM.Email}, Token: {ResetVM.Token}");

        var PassValidation = OnCheckPasswordInput != null 
            ? await OnCheckPasswordInput(ResetVM.Password)
            : true;

        if (PassValidation)
        {
            Loading = string.Empty;
            StateHasChanged();

            var response = await Client.PostAsJsonAsync("/api/Account/ResetPassword", ResetVM);
            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("Password reset successful");
                PassValid = "valid";
                var responseContent = await response.Content.ReadAsStringAsync();
                await Task.Delay(1000);
                if (OnShowToast != null)
                    await OnShowToast(responseContent);
                Loading = "d-none";
                StateHasChanged();
                await Task.Delay(2000);
                Navigation.NavigateTo("/signin");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Reset password request failed! Status: {response.StatusCode}, Content: {errorContent}");
                PassValid = "is-invalid";
                Loading = "d-none";
                StateHasChanged();
                if (OnShowToast != null)
                    await OnShowToast($"Failed to reset password: {errorContent}");
            }
        }
        else
        {
            Console.WriteLine("Validation failed");
            if (OnShowToast != null)
                await OnShowToast("Password validation failed.");
        }
    }

}