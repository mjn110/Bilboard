@using Bilboard.ViewModels
@inject NavigationManager Navigation
@inject HttpClient Client

<EditForm Model="@Email" OnValidSubmit="HandleResetRequest" class="needs-validation" novalidate>
    <DataAnnotationsValidator />

    <div class="form-floating mb-3">
        <InputText @bind-Value="Email" @oninput="(e => OnCheckEmailInput(((ChangeEventArgs)e).Value?.ToString()))" id="Username" type="email" class="@(EmailValid + " form-control")" placeholder="Username" required />
        <label for="Username">Email</label>
        <div class="invalid-tooltip">
            Must be a valid email address.
        </div>
    </div>
    <div class="form-group mb-3 text-center">
        <button type="submit" class="@("btn border btn-block")">
            <span class="@(Loading + " spinner-border spinner-border-sm")" aria-hidden="true"></span>
            Reset Password
        </button>
    </div>
    <div class="text-center">
        <a href="signin">Sign In</a>
        <a>/</a>
        <a href="signup">Sign Up</a>
    </div>
</EditForm>
@code {
    private string Email = string.Empty;
    public string EmailValid { get; set; } = string.Empty;
    public string Loading { get; set; } = "d-none";

    // Callback delegates from parent
    [Parameter]
    public Func<string, Task>? OnShowToast { get; set; }

    [Parameter]
    public Func<string, Task<bool>>? OnCheckEmailInput { get; set; }

    [Parameter]
    public Func<Task>? OnHandleResetRequest { get; set; }

    private async Task HandleResetRequest()
    {
        var EmailValidation = await OnCheckEmailInput(Email);
        if (EmailValidation)
        {
            Loading = string.Empty;
            // Validation succeed so perform sign-in logic here
            var response = await Client.PostAsJsonAsync("/api/Account/ResetPasswordRequest", Email);
            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("Sign in successful");
                EmailValid = "valid";
                await Task.Delay(1000);
                if (OnShowToast != null)
                    await OnShowToast(response.Content.ReadAsStringAsync().Result);
                Loading = "d-none";
                StateHasChanged();
                await Task.Delay(2000);
                Navigation.NavigateTo("/signin");
            }
            else
            {
                Console.WriteLine("Reset password request failed!");
                EmailValid = "is-invalid";
                Loading = "d-none";
                StateHasChanged();
                // Handle error
                if (OnShowToast != null)
                    await OnShowToast("Failed to request password reset.");
            }
        }
        else
        {
            // Validation failed
            Console.WriteLine("Validation failed");
            if (OnShowToast != null)
                await OnShowToast("The email address is not valid.");
            // Handle validation error
        }
    }
}
