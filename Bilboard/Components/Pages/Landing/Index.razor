@page "/"
@layout NewSiteLayout
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bilboard — Prompt in. Dashboard out.</title>
<meta name="description" content="Bilboard is an agentic AI platform that turns prompts into production-ready Blazor dashboards using BIL components — 2.8x more token-efficient than Claude.">
<link rel="preconnect" href="https://api.fontshare.com">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700,900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link href="../fonts/SpaceGrotesk-VariableFont_wght.ttf" rel="stylesheet">
</head>
<noscript>
    <style>
    .reveal{opacity:1 !important;transform:none !important;filter:none !important;}
    .hero-text{opacity:1 !important;transform:none !important;filter:none !important;}
    .chip{opacity:1 !important;filter:none !important;}
    .dash-stage{transform:translate(-50%,0) scale(1) !important;}
    .assemble > *{opacity:1 !important;transform:none !important;}
    .bar-fill.claude{width:100% !important;}
    .bar-fill.bilboard{width:35.7% !important;}
    .scroll-cue{display:none !important;}
    </style>
</noscript>
<body>

<!-- ============ MENU ============ -->
