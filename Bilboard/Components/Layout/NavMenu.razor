@rendermode InteractiveServer

<nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
        <a href="#top" class="navbar-brand brand ps-2 px-md-0 py-md-2">
            <svg width="26" height="26" viewBox="0 0 28 28" fill="none"><rect x="1" y="1" width="11" height="11" rx="3" fill="currentColor" /><rect x="16" y="1" width="11" height="7" rx="3" fill="#0AEF8D" /><rect x="16" y="12" width="11" height="15" rx="3" fill="currentColor" opacity=".18" /><rect x="1" y="16" width="11" height="11" rx="3" fill="currentColor" opacity=".55" /></svg>
            <span>Bilboard</span>
        </a>
        <button class="navbar-toggler btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</nav>

<div class="collapse navbar-collapse" id="navbarNav">
    <nav class="navbar-nav ms-auto nav-scrollable">
        <div class="nav-item px-3 pt-0">
            <NavLink class="nav-link" href="boards" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Boards
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="resources">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Resources
            </NavLink>
        </div>

        <div class="nav-item px-3 pb-1">
            <button type="button" class="nav-link" @onclick="HandleSignOut">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-slash-circle" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                    <path d="M11.354 4.646a.5.5 0 0 0-.708 0l-6 6a.5.5 0 0 0 .708.708l6-6a.5.5 0 0 0 0-.708" />
                </svg> Sign Out
            </button>
        </div>
    </nav>
</div>



@code {
    [Inject]
    private IJwtAuthService JwtAuthService { get; set; }

    [Inject]
    private HttpClient HttpClient { get; set; }

    [Inject]
    private NavigationManager NavigationManager { get; set; }

    private async Task HandleSignOut()
    {
        try
        {
            // Call the SignOut service which handles API call and token cleanup
            await JwtAuthService.SignOutAsync(HttpClient);

            // Redirect to home page
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignOut error: {ex.Message}");
            // Still navigate to home even if there's an error
            NavigationManager.NavigateTo("/");
        }
    }
}

