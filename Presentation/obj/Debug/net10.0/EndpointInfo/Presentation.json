{
  "openapi": "3.1.1",
  "info": {
    "title": "Presentation | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7238"
    },
    {
      "url": "http://localhost:5062"
    }
  ],
  "paths": {
    "/weatherforecast": {
      "get": {
        "tags": [
          "Presentation"
        ],
        "operationId": "GetWeatherForecast",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Component": {
      "get": {
        "tags": [
          "Component"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GetBoardDto"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GetBoardDto"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GetBoardDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Component"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "string"
              }
            },
            "text/json": {
              "schema": {
                "type": "string"
              }
            },
            "application/*+json": {
              "schema": {
                "type": "string"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/createBoardResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/createBoardResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/createBoardResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/Component/{id}": {
      "get": {
        "tags": [
          "Component"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GetBoardDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetBoardDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetBoardDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "createBoardResponseDto": {
        "type": "object",
        "properties": {
          "response": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "GetBoardDto": {
        "type": "object",
        "properties": {
          "boardName": {
            "type": "string"
          }
        }
      },
      "WeatherForecast": {
        "required": [
          "date",
          "temperatureC",
          "summary"
        ],
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          },
          "temperatureF": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Presentation"
    },
    {
      "name": "Component"
    }
  ]
}